{
    "name": "return-stacked-app",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite --open --port 1984",
        "build": "tsc --noEmit && vite build && node -e \"require('fs').renameSync('dist/dev.html','index.html')\"",
        "preview": "vite preview --port 1984",
        "start": "npm run build && npm run preview",
        "audit:fix": "npm audit fix",
        "audit:ci": "npm audit --audit-level=high",
        "lint:ci": "eslint . --max-warnings=0",
        "lint:fix": "eslint . --fix",
        "format:fix": "prettier --write .",
        "format:ci": "prettier --check .",
        "tsc:ci": "tsc --noEmit",
        "test": "npm update --save && npm run format:fix && npm run lint:fix && npm run test:ci",
        "test:ci": "npm audit && npm run lint:ci && npm run tsc:ci && npm run format:ci && npm run build"
    },
    "dependencies": {
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-progress": "^1.1.8",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-separator": "^1.1.8",
        "@radix-ui/react-slider": "^1.3.6",
        "@radix-ui/react-slot": "^1.1.2",
        "@radix-ui/react-switch": "^1.2.6",
        "@radix-ui/react-tabs": "^1.1.13",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^0.477.0",
        "prettier": "^3.8.3",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-router-dom": "^7.15.0",
        "tailwind-merge": "^3.5.0",
        "tailwindcss-animate": "^1.0.7"
    },
    "devDependencies": {
        "@eslint/js": "^9.38.0",
        "@tailwindcss/postcss": "^4.3.0",
        "@types/node": "^20.19.40",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^4.7.0",
        "eslint": "^9.39.4",
        "eslint-plugin-react-hooks": "^5.2.0",
        "globals": "^15.15.0",
        "tailwindcss": "^4",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.59.2",
        "vite": "^6.4.2"
    }
}
